PORT=3000
NODE_ENV=development

DB_PATH=./data/tuzi.db

ACCESS_TOKEN_SECRET=change-me-to-random-string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_SECRET=change-me-to-another-random-string
REFRESH_TOKEN_EXPIRES=7d

TUZI_BASE_URL=https://api.tu-zi.com
TUZI_API_KEY=sk-your-master-key-here
# 服务端请求兔子 API 的超时（毫秒），默认 120000；与官方生成耗时常不一致时可按需调大
# TUZI_HTTP_TIMEOUT_MS=120000

UPLOAD_DIR=./uploads

CLIENT_URL=http://localhost:5173
